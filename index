.status-badge{display:inline-flex;align-items:center;gap:4px;font-size:10.5px;padding:2px 8px;border-radius:20px;background:#dcfce7;color:#16a34a;margin-left:7px;vertical-align:middle;font-weight:600}
.status-badge::before{content:'';width:5px;height:5px;border-radius:50%;background:#16a34a;display:inline-block}
.progress-badge{display:inline-flex;align-items:center;gap:4px;font-size:10.5px;padding:2px 8px;border-radius:20px;background:#eef0fa;color:#7b84c0;margin-left:7px;vertical-align:middle;font-weight:600}
.progress-badge::before{content:'';width:5px;height:5px;border-radius:50%;background:#7b84c0;display:inline-block}

