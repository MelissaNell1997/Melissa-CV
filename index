*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:#e8e8e8;color:#1a1a1a;line-height:1.5}
.cv-wrap{max-width:960px;margin:0 auto;padding:0;background:#fff}
@media print{body{background:#fff}}

/* HERO */
.hero{background:#7b84c0;padding:2.5rem 2rem;display:flex;align-items:center;gap:2rem;flex-wrap:wrap}
.avatar{width:120px;height:120px;border-radius:50%;border:4px solid #a8bedf;flex-shrink:0;overflow:hidden;object-fit:cover;object-position:center top}
.hero-right{flex:1;min-width:200px}
.hero-name{font-size:28px;font-weight:700;color:#fff;line-height:1.2;margin-bottom:5px}
.hero-title{font-size:14px;color:#dde4f5;margin-bottom:14px}
.hero-contacts{display:flex;flex-wrap:wrap;gap:8px}
.contact-pill{display:flex;align-items:center;gap:6px;font-size:12px;color:#dde4f5;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.25);border-radius:20px;padding:4px 11px}
.contact-pill i{font-size:13px;color:#a8bedf}

/* SUMMARY */
.summary-band{background:#a8bedf;padding:1rem 2rem}
.summary-text{font-size:13.5px;color:#1a1a2e;line-height:1.75}

/* BODY */
.cv-body{padding:2rem 2rem}

/* SECTIONS */
.section{margin-bottom:2.5rem}
.section-label{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#7b84c0;margin-bottom:1rem;padding-bottom:6px;border-bottom:2px solid #a8bedf}

/* JOBS */
.job{margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid #e8e8e8}
.job:last-child{border-bottom:none;padding-bottom:0;margin-bottom:0}
.job-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:3px;gap:0.75rem;flex-wrap:wrap}
.job-title{font-size:15px;font-weight:700;color:#1a1a2e;flex:1;min-width:180px}
.job-period{font-size:12px;color:#7b84c0;white-space:nowrap;padding:3px 10px;background:#eef0fa;border-radius:12px;font-weight:500;align-self:flex-start}
.job-company{font-size:13px;color:#555;margin-bottom:12px;display:flex;align-items:center;gap:6px}
.job-company i{font-size:13px;color:#a8bedf}
.job-bullets{list-style:none;display:flex;flex-direction:column;gap:7px}
.job-bullets li{font-size:13px;color:#333;line-height:1.65;display:flex;align-items:flex-start;gap:10px}
.job-bullets li::before{content:'';display:block;width:5px;height:5px;border-radius:50%;background:#a8bedf;margin-top:7px;flex-shrink:0}
.highlight{background:#eef0fa;border-left:4px solid #7b84c0;padding:9px 13px;border-radius:0 7px 7px 0;font-size:13px;color:#1a1a2e;line-height:1.65;font-weight:500}
.highlight::before{display:none!important}

/* SKILLS */
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px}
.skill-group{background:#f5f6fb;border-radius:8px;padding:14px 16px;border:1px solid #dde1f2}
.skill-group-title{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#7b84c0;margin-bottom:10px}
.skill-tags{display:flex;flex-wrap:wrap;gap:6px}
.skill-tag{font-size:12px;color:#333;background:#fff;border:1px solid #c8cee8;border-radius:6px;padding:3px 9px}

/* PROJECTS */
.projects-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}
.project-card{background:#fff;border:1px solid #c8cee8;border-radius:10px;padding:1.1rem 1.25rem}
.project-icon{width:38px;height:38px;border-radius:8px;background:#eef0fa;display:flex;align-items:center;justify-content:center;margin-bottom:12px;font-size:19px;color:#7b84c0}
.project-name{font-size:14px;font-weight:700;color:#1a1a2e;margin-bottom:4px}
.project-type{font-size:11px;color:#888;margin-bottom:10px}
.project-desc{font-size:13px;color:#555;line-height:1.6;margin-bottom:12px}
.project-tags{display:flex;flex-wrap:wrap;gap:5px}
.project-tag{font-size:11px;color:#555;background:#f0f2fa;border-radius:5px;padding:2px 8px}
.project-link{display:inline-flex;align-items:center;gap:5px;font-size:12px;color:#7b84c0;text-decoration:none;margin-top:10px;font-weight:500}
.project-link:hover{text-decoration:underline}
.project-link i{font-size:12px}

/* EDU */
.edu-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
.edu-item{background:#f5f6fb;border-radius:8px;padding:14px 16px;border:1px solid #dde1f2}
.edu-item.in-progress{border:1px solid #7b84c0;background:#eef0fa}
.edu-qual{font-size:13px;font-weight:600;color:#1a1a2e;margin-bottom:2px}
.edu-inst{font-size:12px;color:#555;margin-bottom:4px}
.edu-year{font-size:11px;color:#888}
.in-progress .edu-qual{color:#7b84c0}
.in-progress .edu-inst{color:#7b84c0}
.in-progress .edu-year{color:#a8bedf}

